{
  "name": "polymo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "test": "dotenv -e .env.test -- prisma db push --force-reset && dotenv -e .env.test -- vitest run --passWithNoTests",
    "test:coverage": "dotenv -e .env.test -- prisma db push --force-reset && dotenv -e .env.test -- vitest run --coverage",
    "e2e-test": "dotenv -e .env.test -- prisma db push --force-reset && dotenv -e .env.test -- tsx tests/e2e/seed.ts && dotenv -e .env.test -- playwright test",
    "format": "biome format --write",
    "llm:warm-cache": "dotenv -e .env -- tsx scripts/llm/warm-cache.ts",
    "prepare": "husky",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.38",
    "@ai-sdk/react": "^3.0.77",
    "@anthropic-ai/sdk": "^0.73.0",
    "@aws-sdk/client-s3": "^3.989.0",
    "@clerk/nextjs": "^6.37.3",
    "@hookform/resolvers": "^5.2.2",
    "@next/third-parties": "^16.1.6",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "ai": "^6.0.75",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.1",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.4.0",
    "tar-stream": "^3.1.7",
    "vanilla-cookieconsent": "^3.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@clerk/testing": "^1.13.35",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.2.1",
    "@types/pg": "^8.16.0",
