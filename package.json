    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.2.4",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "outdent": "^0.8.0",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.18"
  }
